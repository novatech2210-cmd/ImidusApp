# Gemfile for iOS Fastlane automation
source "https://rubygems.org"

ruby '>= 3.0.0'

# Fastlane for iOS automation
gem "fastlane", "~> 2.219"

# Plugins
gem "fastlane-plugin-increment_build_number"
gem "fastlane-plugin-versioning"

# Code signing
gem "match"

# TestFlight upload
gem "pilot"

# App Store Connect API
gem "spaceship"

# Additional tools
gem "cocoapods", "~> 1.14"
gem "xcode-install"
