# Matchfile for code signing with Match

# Git repository for storing certificates
git_url(ENV["MATCH_GIT_URL"] || "https://github.com/novatech642/ios-certificates")

# Storage mode (git, google_cloud, s3, gitlab_secure_files)
storage_mode("git")

# App identifier
app_identifier(["com.imidus.customer"])

# Username for Apple Developer Portal
username(ENV["FASTLANE_APPLE_ID"] || "novatech2210@gmail.com")

# Team ID
team_id(ENV["FASTLANE_TEAM_ID"] || "YOUR_TEAM_ID")

# Git branch to use for certificates
git_branch("main")

# Shallow clone (faster)
shallow_clone(true)

# Clone depth
clone_branch_directly(true)

# For more information see: https://docs.fastlane.tools/actions/match/
