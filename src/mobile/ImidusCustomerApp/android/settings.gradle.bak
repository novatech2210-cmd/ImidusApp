pluginManagement {
    includeBuild("../node_modules/@react-native/gradle-plugin/react-native-gradle-plugin")
    includeBuild("../node_modules/@react-native/gradle-plugin/settings-plugin")
    repositories {
        google()
        mavenCentral()
        gradlePluginPortal()
    }
}
rootProject.name = 'com.imidus.customer'
apply from: file("../node_modules/@react-native-community/cli-platform-android/native_modules.gradle"); applyNativeModulesSettingsGradle(settings)
include ':app'
