/**
 * IMIDUS Technologies – ESLint Configuration
 * Brand token enforcement rules.
 * 
 * This config ensures colors are always imported from theme tokens.
 * Prevents visual drift by blocking raw hex codes.
 */
{
  "extends": ["next/core-web-vitals"],
  "rules": {
    "no-restricted-syntax": [
      "error",
      {
        "selector": "Literal[value=/^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$/]",
        "message": "Raw hex colors are not allowed. Import colors from '@/styles/tokens/colors.css' or use CSS variables like var(--brand-blue)."
      }
    ],
    "no-restricted-patterns": [
      "error",
      {
        "pattern": "/rgba?\\([0-9,\\s]+\\)/",
        "message": "Raw rgba/rgb colors should use CSS variables from tokens."
      }
    ]
  }
}
