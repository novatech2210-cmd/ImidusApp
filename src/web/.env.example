# Web Platform Environment Configuration
# Copy this to .env.local for local development (never commit .env.local)

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:5004/api

# Authorize.net Accept.js Configuration
# Get credentials from: https://sandbox.authorize.net/ (sandbox) or https://authorize.net/ (production)
# API Login ID: Found in Account > Security Settings > API Credentials & Keys
# Public Client Key: Generate in Account > Security Settings > Manage Public Client Key
NEXT_PUBLIC_AUTH_NET_API_LOGIN_ID=your_api_login_id
NEXT_PUBLIC_AUTH_NET_PUBLIC_KEY=your_public_client_key
NEXT_PUBLIC_AUTH_NET_ENVIRONMENT=sandbox

# NOTE: Token expiration is 15 minutes - do NOT cache tokens
# Card data goes directly to Authorize.net servers, never to our backend

# Feature Flags
NEXT_PUBLIC_ENABLE_PAYMENTS=true
NEXT_PUBLIC_ENABLE_LOYALTY=true

# Development Settings
NEXT_PUBLIC_DEBUG_MODE=false
