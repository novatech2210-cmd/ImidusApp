# Recursively ignore dependencies and build outputs
**/*.tar.gz
*.zip
*.msi
*.exe
*.apk
*.ipa
node_modules/
.next/
dist/
build/
bin/
obj/
*.user
*.suo
*.cache
.vs/
*.dll
*.exe
*.pdb

# Environment files (DO NOT COMMIT SECRETS)
.env
.env.local
.env.production
*.keystore
*.p12
*.mobileprovision
firebase-admin-key.json
google-services.json
GoogleService-Info.plist

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# GSD Planning (local-only)
.planning/

# Git worktrees (isolated workspaces)
.worktrees/

# Database backups (large binary files)
src/backend/db/backups/*.bak
src/backend/db/backups/*.BAK

# Tool folders
.claude/
.gemini/
.agent/
claude-mem/
.claude-flow/
delivery/
deliverables/
